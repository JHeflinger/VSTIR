	cd /home/aamen/school/spring26/graphics/VSTIR && $(MAKE) $(MAKESILENT) -f src/CMakeFiles/vstir.dir/build.make src/CMakeFiles/vstir.dir/vulkan/vshaders.cpp.s
.PHONY : vulkan/vshaders.cpp.s

